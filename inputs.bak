fdtd.n_cells = 128 128 128  # number of cells
fdtd.max_grid_size = 64     # maximum grid size
fdtd.prob_lo = 0.0 0.0 0.0  # lower-left corner of the domain
fdtd.prob_hi = 1.0 1.0 1.0  # upper-right corner

fdtd.max_step = 100
fdtd.plot_int = 1           # write output every N steps (0 = off)
fdtd.plot_format = numpy    # numpy (.bin + .json) or visit (AMReX plotfiles for VisIt)
fdtd.output_dir = plt # numpy: directory; visit: plotfile prefix (e.g. plt -> plt00000)
fdtd.cfl = 0.8

# Initial condition options:
#   sinwave        : traveling sinusoidal plane wave
#   standingwave   : standing wave seeded with E(x) and B=0 at t=0
#   gaussianpulse  : Gaussian E pulse with B = (1/c) k_hat x E (traveling at t=0)
fdtd.ic = sinwave
fdtd.sinwave_amplitude = 0.01  # E_0 (also used for gaussianpulse)
fdtd.sinwave_dir = 2           # propagation: 0=+x, 1=+y, 2=+z
fdtd.sinwave_pol = 0           # E component: 0=Ex, 1=Ey, 2=Ez (must differ from dir)
fdtd.sinwave_wavelength = -1   # <0: one wavelength along propagation dir (domain length)

# # Gaussian pulse (ic = gaussianpulse); example +x, Ey: E_y = E_0 exp(-r^2/(2 sigma^2)), B_z = E_y/c
# fdtd.ic = gaussianpulse
# fdtd.sinwave_dir = 0
# fdtd.sinwave_pol = 1
# fdtd.pulse_center = 0.2 0.5 0.5   # x0 y0 z0 (default: domain center)
# fdtd.pulse_sigma = 0.05           # sigma; <0 uses 0.1 * min domain extent
