adi.n_cells = 128 128 128  # number of cells
adi.max_grid_size = 64     # maximum grid size
adi.prob_lo = 0.0 0.0 0.0  # lower-left corner of the domain
adi.prob_hi = 1.0 1.0 1.0  # upper-right corner

adi.max_step = 100
adi.plot_int = 1           # write output every N steps (0 = off)
adi.plot_format = numpy    # numpy (.bin + .json) or visit (AMReX plotfiles for VisIt)
adi.output_dir = plt # numpy: directory; visit: plotfile prefix (e.g. plt -> plt00000)
adi.cfl = 0.8              # fraction of 3D Yee CFL limit (not c*dt/dx; see notes/adi.tex)

# Initial condition options:
#   sinwave        : traveling sinusoidal plane wave
#   standingwave   : standing wave seeded with E(x) and B=0 at t=0
#   gaussianpulse  : Gaussian-modulated plane wave along ic_dir (carrier: ic_wavelength)
# adi.ic = sinwave

# Shared by sinwave, standingwave, and gaussianpulse:
adi.ic_amplitude = 0.01    # E_0
adi.ic_dir = 2               # propagation: 0=+x, 1=+y, 2=+z
adi.ic_pol = 0               # E component: 0=Ex, 1=Ey, 2=Ez (must differ from ic_dir)
adi.ic_wavelength = -1       # carrier wavelength along ic_dir (<0 => domain length)

# Gaussian-modulated plane wave (ic = gaussianpulse):
#   E_pol = E_0 exp(-(xi-x0)^2/(2 sigma^2)) cos(k0*(xi-x0)),  B = (1/c) k_hat x E
#   xi is coordinate along ic_dir; pulse_center is xi_0
adi.ic = gaussianpulse
adi.ic_dir = 2
adi.ic_pol = 0
adi.pulse_center = 0.75           # envelope peak xi_0 along ic_dir
adi.pulse_sigma = 0.05           # envelope sigma; <0 => 0.1 * domain length along ic_dir
